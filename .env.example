# API
API_HOST=0.0.0.0
API_PORT=8000

# Paths (relative to project root or absolute)
DATA_DIR=data
STORAGE_DIR=storage

# Embeddings: openai | local
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM: openai | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
RELEVANCE_THRESHOLD=0.25
MAX_INGEST_BYTES=20000000

# Explicit embedding dimension (auto-detected from model name when omitted)
# EMBEDDING_DIMENSION=

# When set, HTTP API requires X-API-Key or Authorization: Bearer
# RAG_API_KEY=
# Keep docs/openapi public while API key is enabled
API_KEY_EXEMPT_DOCS=true

# Optional: add llm_ok / llm_error to GET /health (short probe; uses network)
# HEALTH_CHECK_LLM=false

# Streamlit -> API (must match RAG_API_KEY if the server enforces it)
RAG_API_URL=http://127.0.0.1:8000
# RAG_API_KEY=

# CORS (comma-separated origins, or * when credentials are disabled)
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# HTTP timeout for OpenAI SDK and for Ollama /api/chat (seconds)
OPENAI_TIMEOUT_SECONDS=120

# Optional: cache sentence-transformers / HF models under ./embeddings
# HF_HOME=embeddings

# Logging
LOG_LEVEL=INFO
